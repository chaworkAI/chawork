{
  "name": "chawork",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI Employee Workbench powered by a ChaWork-maintained Codex runtime facade.",
  "license": "Apache-2.0",
  "homepage": "https://chavoai.cn/",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaworkAI/chawork.git"
  },
  "bugs": {
    "url": "https://github.com/chaworkAI/chawork/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:codex-cli": "cargo build --manifest-path chawork-runtime/codex-rs/Cargo.toml -p codex-cli --bin codex",
    "build:chawork-runtime": "cargo build --manifest-path chawork-runtime/codex-rs/Cargo.toml -p chawork-runtime --bin chawork-runtime",
    "build:mcp": "cargo build --manifest-path backend/Cargo.toml --bin chawork-mcp-server",
    "build:runtime": "pnpm run build:mcp && pnpm run build:codex-cli && pnpm run build:chawork-runtime",
    "tauri": "tauri",
    "tauri:dev": "pnpm run build:runtime && cd backend && ../node_modules/.bin/tauri dev",
    "seed:dream-demo": "cargo run --manifest-path backend/Cargo.toml --bin seed_dream_demo --",
    "seed:dream-demo:pending": "cargo run --manifest-path backend/Cargo.toml --bin seed_dream_demo -- --with-pending",
    "migrate:dream-schedules": "cargo run --manifest-path backend/Cargo.toml --bin migrate_dream_schedules",
    "test:hardening": "cargo test --manifest-path backend/Cargo.toml --lib hardening_regression"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "zustand": "^5.0.13"
  }
}
