{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "ChaWork",
  "version": "0.1.0",
  "identifier": "com.chawork.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://api.chawork.com/api/ota/check?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "dangerousInsecureTransportProtocol": true
    }
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$TEMP/**", "$APPDATA/**"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "ChaWork",
        "create": false,
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "resizable": true
      }
    ]
  }
}
